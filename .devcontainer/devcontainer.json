{
  "name": "bun-devcontainer",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",

  "features": {},

  "postCreateCommand": "curl -fsSL https://bun.sh/install | bash && export BUN_INSTALL=$HOME/.bun && export PATH=$BUN_INSTALL/bin:$PATH && bun install",

  "postStartCommand": "export BUN_INSTALL=$HOME/.bun && export PATH=$BUN_INSTALL/bin:$PATH",

  "customizations": {
    "vscode": {
      "settings": {
        "npm.packageManager": "bun",
        "npm.autoDetect": "off",
        "terminal.integrated.env.linux": {
          "PATH": "${containerEnv:HOME}/.bun/bin:${containerEnv:PATH}"
        }
      }
    }
  },

  "remoteEnv": {
    "BUN_INSTALL": "${containerEnv:HOME}/.bun",
    "PATH": "${containerEnv:HOME}/.bun/bin:${containerEnv:PATH}"
  }
}
